. 
. * Define program to calculate indirect effects
. capture program drop med_boot

. program define med_boot, rclass
  1.     args outcome treatment med1 med2 controls
  2.     
.     * Quietly run all three regressions
.     quietly reg `med1' `treatment' `controls'
  3.     local a1 = _b[`treatment']
  4.     
.     quietly reg `med2' `treatment' `controls'
  5.     local a2 = _b[`treatment']
  6.     
.     quietly reg `outcome' `treatment' `med1' `med2' `controls'
  7.     local b1 = _b[`med1']
  8.     local b2 = _b[`med2']
  9.     local cprime = _b[`treatment']
 10.     
.     * Return indirect effects
.     return scalar ind1 = `a1' * `b1'
 11.     return scalar ind2 = `a2' * `b2'
 12.     return scalar total_ind = `a1'*`b1' + `a2'*`b2'
 13.     return scalar direct = `cprime'
 14. end

. 
. * Preserve full dataset
. preserve

. 
. * Keep only complete cases
. keep if !missing(ln_maddison_pcgdp2000, ln_export_area, ethnic_fractionalization, state_dev, `con
> trols')
