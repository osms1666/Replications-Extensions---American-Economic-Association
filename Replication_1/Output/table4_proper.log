. /*------------------------------------------------------------------------------
>   EXTENSION 3: Formal Mediation Analysis
>   Question: What share of the effect works through ethnic frac. vs state dev?
>   Use Baron-Kenny approach + Sobel test
> ------------------------------------------------------------------------------*/
. 
. * Step 1: Total effect (c path)
. quietly reg ln_maddison_pcgdp2000 ln_export_area `colony_fe' `geo'

. estimates store mediation_total

. local c_coef = _b[ln_export_area]

. 
. * Step 2: Effect on mediator 1 - ethnic fractionalization (a1 path)
. quietly reg ethnic_fractionalization ln_export_area `colony_fe' `geo'

. estimates store mediation_ethnic

. local a1_coef = _b[ln_export_area]

. local a1_se = _se[ln_export_area]

. 
. * Step 3: Effect on mediator 2 - state development (a2 path)
. quietly reg state_dev ln_export_area `colony_fe' `geo' if !missing(state_dev)

. estimates store mediation_state

. local a2_coef = _b[ln_export_area]

. local a2_se = _se[ln_export_area]

. 
. * Step 4: Direct effect controlling for mediators (c' path)
. quietly reg ln_maddison_pcgdp2000 ln_export_area ethnic_fractionalization state_dev `colony_fe'
>  `geo' if !missing(ethnic_fractionalization, state_dev)

. estimates store mediation_direct

. local cprime_coef = _b[ln_export_area]

. local b1_coef = _b[ethnic_fractionalization]

. local b1_se = _se[ethnic_fractionalization]

. local b2_coef = _b[state_dev]

. local b2_se = _se[state_dev]

. 
. * Calculate indirect effects and Sobel test
. local indirect1 = `a1_coef' * `b1_coef'

. local sobel_se1 = sqrt(`b1_coef'^2 * `a1_se'^2 + `a1_coef'^2 * `b1_se'^2)

. local sobel_z1 = `indirect1' / `sobel_se1'

. local sobel_p1 = 2*normal(-abs(`sobel_z1'))

. 
. local indirect2 = `a2_coef' * `b2_coef'

. local sobel_se2 = sqrt(`b2_coef'^2 * `a2_se'^2 + `a2_coef'^2 * `b2_se'^2)

. local sobel_z2 = `indirect2' / `sobel_se2'

. local sobel_p2 = 2*normal(-abs(`sobel_z2'))

. 
. local total_indirect = `indirect1' + `indirect2'

. local pct_mediated = (`total_indirect' / `c_coef') * 100

. 
. * Export mediation table
. esttab mediation_total mediation_ethnic mediation_state mediation_direct ///
>     using "$outpath/table_ext3_mediation.rtf", ///
>     replace ///
>     b(%9.3f) se(%9.3f) ///
>     star(* 0.10 ** 0.05 *** 0.01) ///
>     stats(N r2, fmt(%9.0f %9.3f) labels("Observations" "R-squared")) ///
>     mtitles("Total Effect" "→ Ethnic Frac." "→ State Dev." "Direct Effect") ///
>     title("Extension Table 3: Mediation Analysis - Channels of Causality") ///
>     nonotes addnote("Columns show: (1) Total effect of slave exports on GDP" ///
>                      "(2) Effect of slave exports on ethnic fractionalization" ///
>                      "(3) Effect of slave exports on state development" ///
>                      "(4) Direct effect after controlling for both mediators" ///
>                      "Indirect effect via ethnic frac.: " %6.4f `indirect1' " (Sobel z = " %5.2
> f `sobel_z1' ", p = " %5.3f `sobel_p1' ")" ///
>                      "Indirect effect via state dev.: " %6.4f `indirect2' " (Sobel z = " %5.2f 
> `sobel_z2' ", p = " %5.3f `sobel_p2' ")" ///
>                      "Total indirect effect: " %6.4f `total_indirect' " (" %5.1f `pct_mediated'
>  "% of total effect)" ///
>                      "Standard errors in parentheses. * p<0.10, ** p<0.05, *** p<0.01")
