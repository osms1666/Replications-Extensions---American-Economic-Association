. /*--------------------------------------------------------------------------
>   BOOTSTRAP CONFIDENCE INTERVALS
>   5,000 replications for reliable CIs
> ---------------------------------------------------------------------------*/
. 
. * Define program
. capture program drop med_boot

. program define med_boot, rclass
  1.     syntax varlist(min=4) [if]
  2.     
.     tokenize `varlist'
  3.     local outcome `1'
  4.     local treatment `2'
  5.     local med1 `3'
  6.     local med2 `4'
  7.     macro shift 4
  8.     local controls `"`*'"'
  9. 
.     quietly reg `med1' `treatment' `controls'
 10.     local a1 = _b[`treatment']
 11.     
.     quietly reg `med2' `treatment' `controls'
 12.     local a2 = _b[`treatment']
 13.     
.     quietly reg `outcome' `treatment' `med1' `med2' `controls'
 14.     local b1 = _b[`med1']
 15.     local b2 = _b[`med2']
 16.     local cprime = _b[`treatment']
 17.     
.     return scalar ind1 = `a1' * `b1'
 18.     return scalar ind2 = `a2' * `b2'
 19.     return scalar total_ind = `a1'*`b1' + `a2'*`b2'
 20.     return scalar direct = `cprime'
 21. end

. 
. preserve

