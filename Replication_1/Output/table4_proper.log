. /*------------------------------------------------------------------------------
>   EXTENSION 1: Heterogeneity by Region
>   Question: Were some regions more affected than others?
> ------------------------------------------------------------------------------*/
. 
. gen ln_export_x_west = ln_export_area * region_w

. gen ln_export_x_central = ln_export_area * region_c

. gen ln_export_x_east = ln_export_area * region_e

. gen ln_export_x_south = ln_export_area * region_s

. 
. label var ln_export_x_west "Slave exports × West Africa"

. label var ln_export_x_central "Slave exports × Central Africa"

. label var ln_export_x_east "Slave exports × East Africa"

. label var ln_export_x_south "Slave exports × South Africa"

. 
. quietly reg ln_maddison_pcgdp2000 ln_export_area `colony_fe' `geo'

. estimates store het_base

. 
. quietly reg ln_maddison_pcgdp2000 ln_export_area ln_export_x_west ln_export_x_central ln_export
> _x_east ln_export_x_south `colony_fe' `geo'

. estimates store het_region

. 
. test ln_export_x_west = ln_export_x_central = ln_export_x_east = ln_export_x_south

 ( 1)  ln_export_x_west - ln_export_x_central = 0
 ( 2)  ln_export_x_west - ln_export_x_east = 0
 ( 3)  ln_export_x_west - ln_export_x_south = 0

       F(  3,    33) =    1.58
            Prob > F =    0.2136

